{
  "info": {
    "name": "FIT4110 Lab04 IoT Docker Verification",
    "description": "Postman collection reused from Lab 03 style to verify the Dockerized IoT service in Lab 04.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "01_Functional",
      "item": [
        {
          "name": "GET health returns 200",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "health"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Response has status ok', function () { const json = pm.response.json(); pm.expect(json.status).to.eql('ok'); });",
                  "pm.test('Response has service name', function () { const json = pm.response.json(); pm.expect(json).to.have.property('service'); });"
                ]
              }
            }
          ]
        },
        {
          "name": "POST valid reading returns 201",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"device_id\": \"ESP32_01\",\n  \"temperature\": 38.5,\n  \"humidity\": 65,\n  \"motion\": false,\n  \"timestamp\": \"2026-05-18T10:30:00Z\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/readings",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "readings"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 201', function () { pm.response.to.have.status(201); });",
                  "pm.test('Response has readingId and accepted status', function () { const json = pm.response.json(); pm.expect(json).to.have.property('readingId'); pm.expect(json.status).to.eql('accepted'); });",
                  "pm.test('Response device_id matches request', function () { const json = pm.response.json(); pm.expect(json.device_id).to.eql('ESP32_01'); });"
                ]
              }
            }
          ]
        },
        {
          "name": "GET latest reading returns 200 after create",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/readings/latest",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "readings",
                "latest"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200 or mock-compatible 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Response is JSON', function () { pm.response.to.be.json; });"
                ]
              }
            }
          ]
        }
      ]
    },
